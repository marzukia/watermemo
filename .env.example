# ─── Django ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: protect all /api/* endpoints with a bearer token.
# Leave blank to run without authentication (suitable for trusted-network /
# local-only deployments).
# API_KEY=

# ─── Database ───────────────────────────────────────────────────────
# When using docker-compose, DB_HOST should be "db" (the service name).
DB_NAME=watermemo
DB_USER=watermemo
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ─── LLM ────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint.  Default points at a local Ollama instance.
# watermemo uses the native Ollama /api/chat for chat (to support think:false)
# and the OpenAI-compat /v1/embeddings for embeddings.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3.5:35b-a3b
LLM_EMBEDDING_MODEL=nomic-embed-text

# Optional: separate endpoint for embeddings.
# Useful when chat uses a non-Ollama provider (e.g. OpenRouter) but embeddings
# still need to hit a local Ollama for nomic-embed-text.
# Falls back to LLM_BASE_URL / LLM_API_KEY if unset.
# LLM_EMBED_BASE_URL=http://localhost:11434/v1
# LLM_EMBED_API_KEY=ollama

